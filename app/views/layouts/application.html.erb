<!DOCTYPE html>
<html>
  <head>
    <title>Travel Journal</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

<body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary mb-4">
      <div class="container-fluid">
        <span class="navbar-brand">Travel Journal</span>
        <div class="navbar-nav">
          <a class="nav-link" href="/places">Home</a>
          <% if @current_user %>
            <span class="nav-link text-primary">Logged in as: <%= @current_user["username"] %>!</span>
            <a class="nav-link" href="/logout">Logout</a>
          <% else %>
            <a class="nav-link" href="/sessions/new">Login</a>
            <a class="nav-link" href="/users/new">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= yield %>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>