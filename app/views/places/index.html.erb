<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="m-0">Places I've Been</h1>
  <a href="/places/new" class="btn btn-success">New Place</a>
</div>

<div class="list-group">
  <% for place in @places %>
    <a href="/places/<%= place.id %>" class="list-group-item list-group-item-action fs-5">
      <%= place.name %>
    </a>
  <% end %>
</div>